# Puerto del servidor de ajedrez
PORT=8787

# URL pública del cliente web (para armar los links de invitación ?join=)
PUBLIC_WEB_URL=http://localhost:5173

# --- Luna Negra (dejar vacío para modo MOCK / desarrollo sin backend) ---
# Después de completar API key + gameId: `npm run verify:luna` para confirmar.
LUNA_BASE_URL=https://luna-negra-three.vercel.app
# API key server-to-server. NUNCA va al cliente. Se obtiene en /provider.
LUNA_API_KEY=
# gameId del juego "Ajedrez" creado en Luna Negra /provider
LUNA_GAME_ID=
LUNA_GAME_SLUG=ajedrez
# Secret del webhook (§8) para verificar la firma HMAC
LUNA_WEBHOOK_SECRET=
LUNA_LEADERBOARD=ajedrez

# Reloj por jugador en ms (5 min por defecto)
DEFAULT_CLOCK_MS=300000
